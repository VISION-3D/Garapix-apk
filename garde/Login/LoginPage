.logo-container {
  position: relative;
  width: 120px;
  height: 120px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-image {
  width: 100%;
  height: 100%;
  object-fit: contain;
  border-radius: 50%;
  position: relative;
  z-index: 2;
}

.glow-circle {
  position: absolute;
  top: -1px;
  left: -1px;
  right: -1px;
  bottom: -1px;
  border-radius: 50%;
  background: transparent;
  border: 3px solid rgba(46, 125, 50, 0.6);
  box-shadow: 0 0 20px 5px rgba(46, 125, 50, 0.5);
  animation: pulseGlow 2s infinite ease-in-out;
  z-index: 1;
  pointer-events: none;
}

@keyframes pulseGlow {
  0% {
    transform: scale(1);
    opacity: 0.7;
    border-color: rgba(46, 125, 50, 0.8);
    box-shadow: 0 0 20px 5px rgba(46, 125, 50, 0.6);
  }
  50% {
    transform: scale(1.2);
    opacity: 1;
    border-color: rgba(46, 125, 50, 0.9);
    box-shadow: 0 0 40px 15px rgba(46, 125, 50, 0.8);
  }
  100% {
    transform: scale(1);
    opacity: 0.7;
    border-color: rgba(46, 125, 50, 0.8);
    box-shadow: 0 0 20px 5px rgba(46, 125, 50, 0.6);
  }
}
.logo-glow-container {
  position: relative;
  width: 130px;          /* Ajustez selon la taille réelle du logo */
  height: 130px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-image {
  width: 100%;
  height: 100%;
  object-fit: contain;
  border-radius: 50%;    /* Rend l'image circulaire */
  position: relative;
  z-index: 2;
}

.glow-ring {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 2px solid rgba(46, 125, 50, 0.8);
  box-shadow: 0 0 20px 8px rgba(46, 125, 50, 0.5);
  animation: pulseGlow 2.5s infinite ease-in-out;
  z-index: 1;
  pointer-events: none;
}

@keyframes pulseGlow {
  0% {
    box-shadow: 0 0 20px 5px rgba(46, 125, 50, 0.5);
    border-color: rgba(46, 125, 50, 0.8);
  }
  50% {
    box-shadow: 0 0 35px 15px rgba(46, 125, 50, 0.7);
    border-color: rgba(46, 125, 50, 0.9);
  }
  100% {
    box-shadow: 0 0 20px 5px rgba(46, 125, 50, 0.5);
    border-color: rgba(46, 125, 50, 0.8);
  }
}

.logo-glow-container {
  position: relative;
  width: 130px;          /* Ajustez à la taille de votre logo */
  height: 130px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-image {
  width: 100%;
  height: 100%;
  object-fit: contain;
  border-radius: 50%;    /* Rend l'image circulaire */
  position: relative;
  z-index: 10;
}

.wave-ring {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  border: 2px solid rgba(46, 125, 50, 0.8);
  box-shadow: 0 0 10px 2px rgba(46, 125, 50, 0.5);
  opacity: 0;
  z-index: 5;
  pointer-events: none;
}

.wave1 {
  animation: wave 3s infinite ease-out;
}

.wave2 {
  animation: wave 3s infinite 1s ease-out;
}

.wave3 {
  animation: wave 3s infinite 2s ease-out;
}

@keyframes wave {
  0% {
    transform: scale(0.8);
    opacity: 0.8;
    border-width: 3px;
  }
  100% {
    transform: scale(2);
    opacity: 0;
    border-width: 1px;
  }
}